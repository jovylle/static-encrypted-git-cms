CONTENT_DECRYPT_KEY=   # openssl rand -base64 32
CONTENT_PUBLIC_BASE=https://content.jovylle.com
GITHUB_TOKEN=          # required for /admin writeback functions
GITHUB_REPO=jovylle/static-encrypted-git-cms
GITHUB_BRANCH=master
ADMIN_GITHUB_WRITE_MODE=commit   # commit | pr
ADMIN_PASSWORD=                  # plain admin password for /admin login
ADMIN_PASSWORD_HASH=             # optional fallback: scrypt$<saltB64>$<hashB64>
ADMIN_SESSION_SECRET=            # min 16 chars
ADMIN_SESSION_TTL_SECONDS=28800
SYNC_TOKEN=            # optional
NETLIFY_TOKEN=         # optional

# Portfolio rebuild hook — GitHub Actions secret PORTFOLIO_NETLIFY_BUILD_HOOK only (do not commit).
# PORTFOLIO_NETLIFY_BUILD_HOOK=https://api.netlify.com/build_hooks/...
