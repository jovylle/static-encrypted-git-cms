{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["notes", "highlights"],
  "additionalProperties": false,
  "properties": {
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "highlights": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "tag", "year", "technologies", "description"],
        "additionalProperties": true,
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "tag": {
            "type": "string",
            "minLength": 1
          },
          "year": {
            "type": "string",
            "minLength": 1
          },
          "technologies": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label", "url"],
              "additionalProperties": true,
              "properties": {
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "url": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
