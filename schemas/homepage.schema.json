{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "hero": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "tagline": { "type": "string" },
        "description": { "type": "string" },
        "githubHandle": { "type": "string" }
      }
    },
    "ctas": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "route": { "type": "string" },
          "url": { "type": "string" },
          "variant": { "type": "string" }
        }
      }
    }
  }
}
