{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "notifications.schema.json",
  "title": "Notifications",
  "description": "Site-wide announcements and alerts.",
  "type": "object",
  "required": ["notifications"],
  "additionalProperties": false,
  "properties": {
    "notifications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "message", "status", "date"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["info", "success", "warning", "announcement"]
          },
          "status": {
            "type": "string",
            "enum": ["published", "draft", "private"]
          },
          "private": {
            "type": "boolean"
          },
          "date": {
            "type": "string",
            "minLength": 1
          },
          "expiresAt": {
            "type": ["string", "null"]
          },
          "link": {
            "type": "object",
            "required": ["label", "url"],
            "additionalProperties": false,
            "properties": {
              "label": {
                "type": "string",
                "minLength": 1
              },
              "url": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
