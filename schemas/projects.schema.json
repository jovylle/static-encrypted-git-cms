{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["projects"],
  "additionalProperties": false,
  "properties": {
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "body", "status", "private"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "body": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "private": {
            "type": "boolean"
          },
          "thumbnail": {
            "type": ["string", "null"]
          }
        }
      }
    }
  }
}
