{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "publish-controls.schema.json",
  "title": "Publish controls",
  "description": "Collection-level switches for public export behavior.",
  "type": "object",
  "required": ["collections"],
  "additionalProperties": false,
  "properties": {
    "collections": {
      "type": "object",
      "description": "Collection-level public export status.",
      "additionalProperties": false,
      "required": [
        "personal-projects",
        "projects",
        "highlights",
        "profile",
        "resume",
        "blogs"
      ],
      "properties": {
        "personal-projects": { "$ref": "#/$defs/collectionStatus" },
        "projects": { "$ref": "#/$defs/collectionStatus" },
        "highlights": { "$ref": "#/$defs/collectionStatus" },
        "profile": { "$ref": "#/$defs/collectionStatus" },
        "resume": { "$ref": "#/$defs/collectionStatus" },
        "blogs": { "$ref": "#/$defs/collectionStatus" }
      }
    }
  },
  "$defs": {
    "collectionStatus": {
      "type": "string",
      "enum": ["public", "draft", "private"]
    }
  }
}
